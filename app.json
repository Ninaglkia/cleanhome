{
  "expo": {
    "name": "CleanHome",
    "slug": "cleanhome",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "cleanhome",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#022420"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cleanhome.app",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CleanHome usa la tua posizione per trovare i professionisti vicino a te.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.cleanhome.app",
      "adaptiveIcon": {
        "backgroundColor": "#022420",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "react-native-maps",
        { "googleMapsApiKey": "" }
      ]
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#006b55",
      "androidMode": "default",
      "androidCollapsedTitle": "CleanHome"
    }
  }
}

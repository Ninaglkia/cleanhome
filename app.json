    "android": {
      "package": "com.cleanhome.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#022420",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "cleanhome"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#006b55"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CleanHome accede alle foto per caricare l'avatar del profilo e le foto delle case da pulire.",
          "cameraPermission": "CleanHome usa la fotocamera per fotografare il documento d'identità durante la verifica Stripe e per scattare foto degli ambienti da inserire negli annunci."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.cleanhome.app",
          "enableGooglePay": false
        }
      ],
      "@sentry/react-native",
      "expo-secure-store",
      "react-native-bottom-tabs",
      [
        "@react-native-google-signin/google-signin",

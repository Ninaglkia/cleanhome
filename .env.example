# Supabase (client-side — Supabase anon key is public by design)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Places (Maps SDK restricted to the app bundle ID)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Stripe publishable key — safe to expose client-side
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Sentry DSN — safe to expose client-side
EXPO_PUBLIC_SENTRY_DSN=

# Server-only secrets (never ship to client)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
